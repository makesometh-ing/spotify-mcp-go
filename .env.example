# Required: Spotify app credentials from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here

# Optional: Server port (default: 8080)
# SPOTIFY_MCP_PORT=8080

# Optional: Token storage path (default: ~/.config/spotify-mcp-go/auth/tokens.db)
# SPOTIFY_MCP_TOKEN_DB=~/.config/spotify-mcp-go/auth/tokens.db
